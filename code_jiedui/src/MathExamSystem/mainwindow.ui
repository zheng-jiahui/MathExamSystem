 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1000</width>
    <height>700</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>数学考试系统</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QMainWindow {
      background: white;
      font-family: &quot;Microsoft YaHei&quot;, &quot;Segoe UI&quot;, sans-serif;
  }

  QWidget {
      background: transparent;
  }

  QGroupBox {
      background: white;
      border: 2px solid #f5a596;
      border-radius: 20px;
      margin-top: 15px;
      padding-top: 20px;
      font-weight: bold;
      color: #ce7e73;
  }

  QGroupBox::title {
      subcontrol-origin: margin;
      left: 20px;
      padding: 0 15px 0 15px;
      color: #ce7e73;
      font-size: 18px;
      font-weight: bold;
  }

  QLabel {
      background: transparent;
      color: #ce7e73;
      font-size: 16px;
      font-weight: bold;
  }

  QLabel#titleLabel {
      font-size: 36px;
      font-weight: bold;
      color: #ce7e73;
      background: transparent;
  }

  QLineEdit, QComboBox, QSpinBox {
      background: white;
      border: 2px solid #f5a596;
      border-radius: 12px;
      padding: 12px;
      font-size: 16px;
      selection-background-color: #fad5ce;
      color: #ce7e73;
  }

  QLineEdit:focus, QComboBox:focus, QSpinBox:focus {
      border-color: #ce7e73;
      background: white;
      border-width: 3px;
  }

  QTextEdit {
      background: white;
      border: 2px solid #f5a596;
      border-radius: 12px;
      padding: 12px;
      font-size: 16px;
      color: #ce7e73;
  }

  QTextEdit:focus {
      border-color: #ce7e73;
      border-width: 3px;
  }

  QPushButton {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                  stop:0 #f5a596, stop:1 #ce7e73);
      border: none;
      border-radius: 12px;
      color: white;
      padding: 15px 30px;
      font-size: 16px;
      font-weight: bold;
      min-width: 140px;
  }

  QPushButton:hover {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                  stop:0 #f5a596, stop:1 #d88c7d);
  }

  QPushButton:pressed {
      background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                  stop:0 #ce7e73, stop:1 #b86a5a);
  }

  QPushButton:disabled {
      background: #fad5ce;
      color: #ce7e73;
  }

  QRadioButton {
      background: transparent;
      color: #ce7e73;
      font-size: 16px;
      font-weight: bold;
      spacing: 10px;
  }

  QRadioButton::indicator {
      width: 20px;
      height: 20px;
      border-radius: 10px;
      border: 2px solid #f5a596;
      background: white;
  }

  QRadioButton::indicator:checked {
      background: #ce7e73;
      border: 2px solid #ce7e73;
  }

  QRadioButton::indicator:checked:hover {
      background: #d88c7d;
      border: 2px solid #d88c7d;
  }

  QProgressBar {
      border: 2px solid #f5a596;
      border-radius: 12px;
      background: white;
      text-align: center;
      color: #ce7e73;
      font-weight: bold;
      font-size: 14px;
  }

  QProgressBar::chunk {
      background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                                  stop:0 #fad5ce, stop:0.5 #f5a596, stop:1 #ce7e73);
      border-radius: 10px;
  }

  QStackedWidget {
      background: white;
  }</string>
  </property>
